# --- xAI (required for /api/underwrite) ---
# Plain key, OR Vercel xAI integration (injects a name ending in _XAI_API_KEY, e.g. AI123456789_XAI_API_KEY).
# Set only in Vercel Environment Variables or .env.local — never VITE_* (that would expose secrets to the browser).
# XAI_API_KEY="xai-..."
# Example integration-style name (use the exact name Vercel shows you):
# AI123456789_XAI_API_KEY="xai-..."

# Optional. Default: grok-4-fast. Other Grok 4 family options documented by xAI include
# grok-4-fast-reasoning and grok-4-1-fast-reasoning.
# XAI_MODEL=grok-4-fast

# Optional: fallback if XAI_MODEL unset.
# AI_MODEL=grok-4-fast

# PDF handling for /api/underwrite:
# PDFs are now sent as extracted text by default; images are sent as multimodal image parts when present.
# If multimodal image understanding fails, the server automatically retries text-only.

# APP_URL: Optional; base URL when deployed (e.g. Cloud Run).
APP_URL="MY_APP_URL"
