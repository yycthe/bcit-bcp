# --- xAI (preferred if set) ---
# Plain key, OR use Vercel xAI integration (creates PREFIX_XAI_API_KEY — no copy needed).
# XAI_API_KEY="xai-..."

# Optional. Default: grok-3-mini-latest (low-cost; good for PDF/images via AI SDK file parts).
# If PDF quality is weak, try: grok-2-vision-1212
# XAI_MODEL=grok-3-mini-latest

# --- Vercel AI Gateway (fallback when no xAI key) ---
# AI_GATEWAY_API_KEY="your_gateway_api_key_here"
# AI_GATEWAY_MODEL=google/gemini-2.0-flash

# Optional: shared override (xAI path prefers XAI_MODEL first).
# AI_MODEL=grok-3-mini-latest

# APP_URL: Optional; base URL when deployed (e.g. Cloud Run).
APP_URL="MY_APP_URL"
