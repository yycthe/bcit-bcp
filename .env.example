# AI_GATEWAY_API_KEY: Vercel AI Gateway API key (Dashboard → AI Gateway).
# Used only on the server (Vercel Function /api/underwrite and Vite dev middleware).
# On Vercel Production/Preview you can use OIDC instead and omit this if configured.
AI_GATEWAY_API_KEY="your_gateway_api_key_here"

# Optional: model id routed by the gateway, e.g. openai/gpt-5.4, anthropic/claude-sonnet-4.6
# AI_GATEWAY_MODEL=openai/gpt-4o

# APP_URL: Optional; base URL when deployed (e.g. Cloud Run).
APP_URL="MY_APP_URL"
