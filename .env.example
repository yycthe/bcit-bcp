# --- xAI (required for /api/underwrite) ---
# Plain key, OR Vercel xAI integration (injects a name ending in _XAI_API_KEY, e.g. AI123456789_XAI_API_KEY).
# Set only in Vercel Environment Variables or .env.local — never VITE_* (that would expose secrets to the browser).
# XAI_API_KEY="xai-..."
# Example integration-style name (use the exact name Vercel shows you):
# AI123456789_XAI_API_KEY="xai-..."

# Optional. Default: grok-4-1-fast-reasoning (Grok 4.1 Fast, reasoning). Alternatives: grok-4-1-fast-non-reasoning, grok-4, grok-3-mini-latest
# XAI_MODEL=grok-4-1-fast-reasoning

# Optional: fallback if XAI_MODEL unset.
# AI_MODEL=grok-4-1-fast-reasoning

# PDF handling for /api/underwrite (default: native PDF file parts to xAI; auto text fallback if the API rejects):
# XAI_UNDERWRITE_PDF_TEXT_ONLY=true     — force old path: no binary PDF, only unpdf-extracted text
# XAI_UNDERWRITE_PDF_TEXT_SUPPLEMENT=true — native PDF + also append unpdf text (higher token use)

# APP_URL: Optional; base URL when deployed (e.g. Cloud Run).
APP_URL="MY_APP_URL"
